{
  "contractVersion": "v1",
  "backend": "skill:crypto-hash.hash",
  "input": {
    "type": "object",
    "required": ["request"],
    "properties": {
      "request": {
        "type": "object",
        "required": ["algorithm", "data"],
        "properties": {
          "algorithm": {
            "type": "string",
            "enum": ["sha256", "sha512", "sha3-256", "keccak256", "blake2b", "blake3", "sha1", "ripemd160"]
          },
          "data": {
            "type": "string",
            "description": "Hex-encoded input data"
          },
          "encoding": {
            "type": "string",
            "enum": ["hex", "utf8"],
            "description": "Optional encoding of the input data"
          }
        }
      }
    }
  },
  "output": {
    "type": "object",
    "required": ["hash", "algorithm", "bytes", "backend"],
    "properties": {
      "hash": {
        "type": "string",
        "pattern": "^0x[0-9a-fA-F]+$"
      },
      "algorithm": {
        "type": "string"
      },
      "bytes": {
        "type": "number"
      },
      "backend": {
        "type": "string",
        "const": "skill:crypto-hash.hash"
      }
    }
  }
}
