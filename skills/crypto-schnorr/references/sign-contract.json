{
  "contractVersion": "v1",
  "backend": "skill:crypto-schnorr.sign",
  "input": {
    "type": "object",
    "required": ["request"],
    "properties": {
      "request": {
        "type": "object",
        "required": ["privateKey", "message"],
        "properties": {
          "privateKey": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{64}$",
            "description": "Hex-encoded 32-byte private key"
          },
          "message": {
            "type": "string",
            "description": "Hex-encoded message to sign"
          }
        }
      }
    }
  },
  "output": {
    "type": "object",
    "required": ["signature", "publicKey", "backend"],
    "properties": {
      "signature": {
        "type": "string",
        "pattern": "^[0-9a-fA-F]{128}$",
        "description": "Hex-encoded 64-byte tos-schnorr-ristretto255 signature"
      },
      "publicKey": {
        "type": "string",
        "pattern": "^[0-9a-fA-F]{64}$",
        "description": "Hex-encoded 32-byte public key"
      },
      "backend": {
        "type": "string",
        "const": "skill:crypto-schnorr.sign"
      }
    }
  }
}
