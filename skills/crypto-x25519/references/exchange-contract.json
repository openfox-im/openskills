{
  "contractVersion": "v1",
  "backend": "skill:crypto-x25519.exchange",
  "input": {
    "type": "object",
    "required": ["request"],
    "properties": {
      "request": {
        "type": "object",
        "required": ["privateKey", "peerPublicKey"],
        "properties": {
          "privateKey": {
            "type": "string",
            "description": "Hex-encoded private key"
          },
          "peerPublicKey": {
            "type": "string",
            "description": "Hex-encoded peer public key"
          }
        }
      }
    }
  },
  "output": {
    "type": "object",
    "required": ["sharedSecret", "backend"],
    "properties": {
      "sharedSecret": {
        "type": "string",
        "description": "Hex-encoded shared secret"
      },
      "backend": {
        "type": "string",
        "const": "skill:crypto-x25519.exchange"
      }
    }
  }
}
