{
  "contractVersion": "v1",
  "backend": "skill:crypto-rangeproofs.verify",
  "input": {
    "type": "object",
    "required": ["request"],
    "properties": {
      "request": {
        "type": "object",
        "required": ["proof", "commitments", "bitLengths"],
        "properties": {
          "proof": {
            "type": "string",
            "description": "Hex-encoded range proof"
          },
          "commitments": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of hex-encoded commitments"
          },
          "bitLengths": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "description": "Array of bit lengths for each commitment"
          }
        }
      }
    }
  },
  "output": {
    "type": "object",
    "required": ["valid", "backend"],
    "properties": {
      "valid": {
        "type": "boolean"
      },
      "backend": {
        "type": "string",
        "const": "skill:crypto-rangeproofs.verify"
      }
    }
  }
}
