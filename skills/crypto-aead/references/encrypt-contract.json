{
  "contractVersion": "v1",
  "backend": "skill:crypto-aead.encrypt",
  "input": {
    "type": "object",
    "required": ["request"],
    "properties": {
      "request": {
        "type": "object",
        "required": ["algorithm", "key", "nonce", "plaintext"],
        "properties": {
          "algorithm": {
            "type": "string",
            "enum": ["aes-256-gcm", "chacha20-poly1305"]
          },
          "key": {
            "type": "string",
            "description": "Hex-encoded encryption key"
          },
          "nonce": {
            "type": "string",
            "description": "Hex-encoded nonce"
          },
          "plaintext": {
            "type": "string",
            "description": "Hex-encoded plaintext"
          },
          "aad": {
            "type": "string",
            "description": "Optional hex-encoded additional authenticated data"
          }
        }
      }
    }
  },
  "output": {
    "type": "object",
    "required": ["ciphertext", "tag", "backend"],
    "properties": {
      "ciphertext": {
        "type": "string",
        "description": "Hex-encoded ciphertext"
      },
      "tag": {
        "type": "string",
        "description": "Hex-encoded authentication tag"
      },
      "backend": {
        "type": "string",
        "const": "skill:crypto-aead.encrypt"
      }
    }
  }
}
