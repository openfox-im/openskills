{
  "contractVersion": "v1",
  "backend": "skill:crypto-uno-proofs.verify",
  "input": {
    "type": "object",
    "required": ["request"],
    "properties": {
      "request": {
        "type": "object",
        "required": ["proofType", "proof", "params"],
        "properties": {
          "proofType": {
            "type": "string",
            "enum": ["shield", "ct_validity", "commitment_eq", "balance"]
          },
          "proof": {
            "type": "string",
            "description": "Hex-encoded proof"
          },
          "params": {
            "type": "object",
            "description": "Proof-type-specific parameters"
          }
        }
      }
    }
  },
  "output": {
    "type": "object",
    "required": ["valid", "proofType", "backend"],
    "properties": {
      "valid": {
        "type": "boolean"
      },
      "proofType": {
        "type": "string"
      },
      "backend": {
        "type": "string",
        "const": "skill:crypto-uno-proofs.verify"
      }
    }
  }
}
